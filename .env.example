# Database (PostgreSQL)
# Local Docker: postgresql://hotel:hotel@localhost:5432/hotel_billing?schema=public
# Neon/Supabase/Vercel Postgres: use the connection string from your provider
DATABASE_URL="postgresql://hotel:hotel@localhost:5432/hotel_billing?schema=public"

# Auth — required in production (use a long random string, e.g. openssl rand -base64 32)
JWT_SECRET="change-me-in-production"

# File storage
# local = filesystem (default for development)
# blob = Vercel Blob (auto-selected when BLOB_READ_WRITE_TOKEN is set)
STORAGE_DRIVER="local"

# Local upload directory (only used when STORAGE_DRIVER=local)
UPLOAD_DIR="./uploads"

# Vercel Blob — required for production file uploads on Vercel
# Create at: Vercel Dashboard → Storage → Blob → Connect to project
BLOB_READ_WRITE_TOKEN=""

# Node environment (set automatically on most hosts)
NODE_ENV="development"
